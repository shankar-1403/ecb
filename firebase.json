{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": "./dist",
    "ignore": [
      "**/.*",
      "**/.DS_Store"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "*.claude"
      ]
    }
  ]
}
